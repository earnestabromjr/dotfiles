{
   "action": {
      "default_icon": {
         "16": "icons/action_16.png",
         "32": "icons/action_32.png"
      }
   },
   "background": {
      "service_worker": "js/background.bundle.js"
   },
   "chrome_url_overrides": {
      "newtab": "index.html"
   },
   "content_scripts": [ {
      "all_frames": false,
      "js": [ "js/ping.bundle.js" ],
      "matches": [ "https://daily.dev/*", "https://*.daily.dev/*" ],
      "run_at": "document_start"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self';"
   },
   "default_locale": "en",
   "description": "__MSG_extensionDescription__",
   "homepage_url": "https://daily.dev",
   "host_permissions": [ "https://daily.dev/", "https://*.daily.dev/", "https://dailynow.co/", "https://*.dailynow.co/" ],
   "icons": {
      "128": "icons/128.png",
      "16": "icons/16.png",
      "48": "icons/48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_extensionName__",
   "offline_enabled": true,
   "optional_host_permissions": [ "*://*/*" ],
   "optional_permissions": [ "topSites", "bookmarks", "declarativeNetRequestWithHostAccess" ],
   "permissions": [ "scripting" ],
   "short_name": "daily.dev",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "3.45.4",
   "web_accessible_resources": [ {
      "matches": [ "*://*/*" ],
      "resources": [ "index.html", "companion.html", "js/companion.bundle.js", "css/companion.css" ]
   }, {
      "matches": [ "https://daily.dev/*", "https://*.daily.dev/*", "https://staging.daily.dev/*", "https://*.staging.daily.dev/*" ],
      "resources": [ "frame.html", "js/frame.bundle.js" ]
   } ]
}
