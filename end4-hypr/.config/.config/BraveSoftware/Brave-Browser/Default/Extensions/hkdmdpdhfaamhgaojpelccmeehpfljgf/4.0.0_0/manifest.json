{
   "action": {
      "default_icon": "icons/icon_inactive.png",
      "default_popup": "src/popup/index.html",
      "default_title": "__MSG_action_title__"
   },
   "background": {
      "service_worker": "background/service_worker.js",
      "type": "module"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content_scripts/content_script.js" ],
      "matches": [ "*://*/*" ],
      "run_at": "document_end"
   }, {
      "js": [ "content_scripts/bridge.js" ],
      "matches": [ "*://app.vidow.io/video/stream/*", "*://app.vidow.io/video/cast/*" ],
      "run_at": "document_start"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self';"
   },
   "default_locale": "en",
   "description": "__MSG_desc__",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "icons/128.png",
      "16": "icons/16.png",
      "19": "icons/19.png",
      "38": "icons/38.png",
      "48": "icons/48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_name__",
   "optional_permissions": [ "downloads" ],
   "options_ui": {
      "open_in_tab": true,
      "page": "src/options/index.html"
   },
   "permissions": [ "tabs", "webRequest", "declarativeNetRequest", "storage" ],
   "short_name": "__MSG_short_name__",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "4.0.0"
}
