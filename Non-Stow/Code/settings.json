{
    "security.workspace.trust.untrustedFiles": "open",
    "keyboard.dispatch": "keyCode",
  "editor.fontFamily": "'FiraCode Nerd Font', 'JetBrains Mono', monospace",
  "editor.fontSize": 14,
  "workbench.sideBar.location": "right",
  "workbench.activityBar.location": "top",
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.colorCustomizations": {},
  "remote.SSH.remotePlatform": {
    "*.gitpod.io": "linux"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode"
  },
  "workbench.colorTheme": "SLab Bearded Theme Monokai Metallian",
  "vim.useCtrlKeys": false,
  "git.enableSmartCommit": true,
  "cSpell.userWords": ["ifaddresses", "matugen", "wallust"],
  "files.autoSave": "afterDelay",
  "[jsonc]": {
    "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
  },
  "vim.handleKeys": {
    "<C-b>": false,
    "<C-d>": true,
    "<C-s>": false,
    "<C-z>": false,
    "<C-n": true
  },
  "vim.leader": "<space>",
  "vim.normalModeKeyBindings": [
    {
      "before": ["<leader>", "|"],
      "commands": ["workbench.action.splitEditorRight"]
    },
    {
      "before": ["<leader>", "-"],
      "commands": ["workbench.action.splitEditorDown"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<space>"],
      "commands": ["whichkey.show"]
    },
    {
      "before": ["<leader>", "/"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "f"],
      "commands": ["workbench.action.findInFiles"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<space>"],
      "commands": ["whichkey.show"]
    }
  ],
  "vim.useSystemClipboard": true,
  "vim.highlightedyank.enable": true,
  "vim.smartRelativeLine": true,
  "vim.autoindent": true,
  "vim.easymotion": true,
  "vim.easymotionDimBackground": true,
  "vim.cursorStylePerMode.insert": "line",
  "codeium.enableConfig": {
    "*": true,
    "properties": true,
    "javascript": false,
    "ansible": true
  },
  "terminal.integrated.fontFamily": "'FiraCode Nerd Font','JetBrainsMonoNL Nerd Font'",
  "editor.fontLigatures": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "dev.containers.dockerPath": "/home/anakin/.local/bin/podman-host",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "codeium.disableSupercomplete": true,
  "explorer.compactFolders": false,
  "vs-kubernetes": {
    "vscode-kubernetes.helm-path-linux": "/home/anakin/.local/state/vs-kubernetes/tools/helm/linux-amd64/helm",
    "vscode-kubernetes.kubectl-path-linux": "/home/anakin/.local/state/vs-kubernetes/tools/kubectl/kubectl",
    "vscode-kubernetes.minikube-path-linux": "/home/anakin/.local/state/vs-kubernetes/tools/minikube/linux-amd64/minikube"
  },
  "git.autofetch": true,
  "ansible.lightspeed.enabled": false,
  "ansible.lightspeed.suggestions.enabled": false,
  "editor.lineNumbers": "relative",
  "editor.formatOnSave": true,
  "notebook.formatOnSave.enabled": true,
  "pylint.severity": {
    "C0114": "Hint",
    "C0115": "Hint",
    "C0116": "Hint",
    "C0303": "Hint"
  },
  "editor.linkedEditing": true,
  "workbench.iconTheme": "fira-code-material-minimal",
  "c-cpp-flylint.language": "c",
  "[elixir]": {
    "editor.defaultFormatter": "JakeBecker.elixir-ls",
    "editor.formatOnSave": true,
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.wordBasedSuggestions": "off",
    "editor.formatOnType": true,
    "editor.trimAutoWhitespace": false,
    "editor.snippetSuggestions": "inline",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true
  },
  "elixirLS.dialyzerFormat": "dialyxir_long",
  "elixirLS.dialyzerWarnOpts": [],
  "elixirLS.fetchDeps": false,
  "elixirLS.suggestSpecs": false,
  "elixirLS.signatureAfterComplete": false,
  "files.associations": {
    "*.ex": "elixir",
    "*.exs": "elixir",
    "*.eex": "phoenix-heex",
    "*.heex": "phoenix-heex",
    "*.leex": "phoenix-heex"
  },
  "emmet.includeLanguages": {
    "phoenix-heex": "html"
  },
  "elixirLS.trace.server": "messages",
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua"
  },
  "direnv.path.executable": "/usr/bin/direnv"
}